# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dealhunter

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-min-32-chars-random-string
JWT_EXPIRES_IN=7d

# ── CORS ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend.onrender.com

# ── Discovery ──────────────────────────────────────────────────────────────────
SCAN_ON_START=false
PROXY_KILL_SWITCH=false
PROXY_ENABLED=true
SAFE_PROXY_MODE=true
CYCLE_MAX_PROXY_REQ=50
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSERS_PATH=./pw-browsers
PAGE_TIMEOUT_MS=60000

# ── Proxy (BrightData residential) — worker only ───────────────────────────────
PROXY_HOST=brd.superproxy.io
PROXY_PORT=22225
PROXY_USER=brd-customer-XXXX-zone-residential_proxy1-country-us
PROXY_PASS=your-proxy-password

# ── ISP Proxy (BrightData ISP) — worker only ──────────────────────────────────
ISP_PROXY_HOST=brd.superproxy.io
ISP_PROXY_PORT=33335
ISP_PROXY_USER=brd-customer-XXXX-zone-isp_proxy1
ISP_PROXY_PASS=your-isp-proxy-password
ISP_PROXY_ENABLED=true

# ── Keepa ──────────────────────────────────────────────────────────────────────
KEEPA_API_KEY=your-keepa-api-key
KEEPA_ENABLED=true
KEEPA_DOMAIN=1
KEEPA_CACHE_HOURS=24

# ── eBay ───────────────────────────────────────────────────────────────────────
EBAY_ENABLED=true
EBAY_CACHE_HOURS=24

# ── Google Maps ────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Email (SMTP) — optional, alerts won't send without it ─────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ── Stripe — optional, payments won't work without it ─────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ELITE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
