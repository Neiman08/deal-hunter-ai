# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dealhunter
# Or individual params:
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=dealhunter
# PGUSER=postgres
# PGPASSWORD=your_password

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# ── Scanning ──────────────────────────────────────────────────────────────────
REQUEST_DELAY_MS=2500
SCAN_INTERVAL_MINUTES=15
WALMART_API_KEY=         # Optional: Walmart Affiliate API key
HD_STORE_ID=6906         # Default Home Depot store number

# ── Stripe (Subscriptions) ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...     # Monthly Pro plan price ID
STRIPE_ELITE_PRICE_ID=price_...   # Monthly Elite plan price ID

# ── Twilio (WhatsApp Alerts) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=+14155238886  # Twilio sandbox or your approved number

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password        # Gmail App Password (not your main password)

# ── Maps ──────────────────────────────────────────────────────────────────────
MAPBOX_TOKEN=pk.eyJ1...            # Mapbox public token (also set in frontend .env)

# ── Redis (optional, for caching) ────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379
