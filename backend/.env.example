# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dealhunter

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_64_chars
JWT_EXPIRES_IN=7d

# ── Frontend URL (set to deployed URL in production) ──────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Scanner / Playwright ──────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true
PAGE_TIMEOUT_MS=30000
SCAN_ON_START=false
ACTIVE_STORES=best-buy,office-depot,gamestop
BLOCK_RESOURCES=true

# ── Proxy (optional, for scraping) ───────────────────────────────────────────
PROXY_ENABLED=false
PROXY_PROVIDER=smartproxy
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=

# ISP Proxy (for stores that block datacenter IPs)
ISP_PROXY_ENABLED=false
ISP_PROXY_HOST=
ISP_PROXY_PORT=
ISP_PROXY_USER=
ISP_PROXY_PASS=

# ── Google Maps / Places API ─────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Keepa (Amazon price history enrichment) ──────────────────────────────────
KEEPA_API_KEY=your_keepa_api_key_here
KEEPA_ENABLED=true

# ── eBay (resale price lookup) ───────────────────────────────────────────────
EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret
EBAY_ENABLED=true

# ── Stripe (Subscriptions) ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ELITE_PRICE_ID=price_...

# ── Twilio (WhatsApp Alerts) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=+14155238886

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
